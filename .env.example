# Application
APP_NAME="FastAPI Template"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://fastapi:secret@localhost:5432/fastapi_db

# JWT
JWT_SECRET_KEY=CHANGE-ME-to-a-random-64-char-string-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Logging
LOG_LEVEL=DEBUG
LOG_JSON_FORMAT=false

# Rate Limiting
RATE_LIMIT_AUTH=5/minute
