# Core model
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
USE_OPENAI_LLM=false

# Lab guardrail behavior
ENABLE_LOCAL_GUARDRAILS=true
ENABLE_CLOUD_SAFETY=false
CLOUD_SAFETY_PROVIDER=aws
CLOUD_SAFETY_THRESHOLD=4

# AWS Bedrock Guardrails
AWS_REGION=us-east-1
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=DRAFT

# LangSmith
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=kdu-production-guardrails-lab
TRACE_SAMPLE_POLICY=guardrail_triggered
TRACE_SAMPLE_RATE=1.0
TRACE_REDACT_PII=true
